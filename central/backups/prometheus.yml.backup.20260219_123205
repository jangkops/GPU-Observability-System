global:
  scrape_interval: 15s
  evaluation_interval: 15s
alerting:
  alertmanagers:
  - static_configs:
    - targets:
      - alertmanager:9093
rule_files:
- /etc/prometheus/alerts.yml
scrape_configs:
- job_name: prometheus
  static_configs:
  - targets:
    - localhost:9090
- job_name: g5-system
  static_configs:
  - targets:
    - 10.0.1.101:9100
    - 10.0.1.101:9400
    - 10.0.1.101:9500
    labels:
      instance: g5
      instance_type: g5.12xlarge
- job_name: g5-process
  static_configs:
  - targets:
    - 10.0.1.101:9256
    labels:
      instance: g5
      instance_type: g5.12xlarge
  metric_relabel_configs:
  - source_labels:
    - groupname
    regex: ([^;]+);(.+)
    replacement: $1
    target_label: processname
    action: replace
  - source_labels:
    - groupname
    regex: ([^;]+);(.+)
    replacement: $2
    target_label: username
    action: replace
